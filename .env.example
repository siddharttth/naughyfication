# HTTP server bind address.
HTTP_ADDRESS=:8080

# Public API key used by clients to authenticate requests.
API_KEY=dev-secret-key

# PostgreSQL connection string for application data and metadata.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/postgres?sslmode=disable

# Redis host:port used by the current application runtime.
REDIS_ADDRESS=127.0.0.1:6379

# Optional Redis URL for tooling, wrappers, or future compatibility.
REDIS_URL=redis://127.0.0.1:6379

# Worker concurrency for background delivery processing.
WORKER_COUNT=4

# Maximum number of delivery attempts before a notification is marked failed.
MAX_RETRIES=3

# Base retry delay used for exponential backoff.
BASE_BACKOFF=2s

# Upper bound for retry backoff delay.
MAX_BACKOFF=30s

# Timeout for provider calls such as SMTP delivery.
PROVIDER_TIMEOUT=10s

# SMTP host for real email delivery. Leave empty to use mock delivery.
SMTP_HOST=

# SMTP port for the configured mail server.
SMTP_PORT=587

# SMTP username for authenticated providers.
SMTP_USERNAME=

# SMTP password or app password for authenticated providers.
SMTP_PASSWORD=

# Verified sender address used in outgoing email.
SMTP_FROM=no-reply@naughtyfication.local

# When true, email sends are logged instead of sent if SMTP_HOST is empty.
ALLOW_MOCK_DELIVERY=true
